# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/prepzo

# JWT Secrets (minimum 32 characters, use strong random strings in production)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters

# Encryption Key (exactly 32 bytes for AES-256)
ENCRYPTION_KEY=your-32-byte-encryption-key12345

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Cookie Settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Email Configuration (for OTP and notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@prepzo.com

# AI API Keys (never expose to frontend)
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Internal AI Service (Prepzo AI)
USE_INTERNAL_AI=true
AI_SERVICE_URL=http://localhost:8000
AI_API_KEY=prepzo-ai-secret-key

# Rate Limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Settings
BCRYPT_SALT_ROUNDS=12
PASSWORD_HISTORY_COUNT=5
ACCOUNT_LOCKOUT_ATTEMPTS=5
OTP_EXPIRY_MINUTES=10

# Proctoring Settings
PROCTORING_RETENTION_DAYS=30

# Admin Settings (create initial admin user)
ADMIN_EMAIL=admin@prepzo.com
ADMIN_PASSWORD=AdminSecurePassword123!
